---
// Categories landing -> `/categories/`. This is an ADDITIVE improvement over the
// old site (which had per-category pages but no landing index).
import ListLayout from '../../layouts/ListLayout.astro';
import { getSortedPosts } from '../../utils/posts';
import { getCategories } from '../../utils/taxonomy';

const posts = await getSortedPosts();
const categories = getCategories(posts);
---

<ListLayout title="Categories" description="Browse every post by category.">
  <ul class="taxonomy-cloud">
    {
      categories.map((category) => (
        <li>
          <a href={`/categories/${category.slug}/`}>
            {category.name} <span class="count">({category.posts.length})</span>
          </a>
        </li>
      ))
    }
  </ul>
</ListLayout>
