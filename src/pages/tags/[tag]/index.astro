---
// Per-tag archive -> `/tags/<slug>/`. Index-style route so `preserve` emits a
// directory with index.html (trailing-slash URL), matching the old site.
import ListLayout from '../../../layouts/ListLayout.astro';
import PostList from '../../../components/PostList.astro';
import { getSortedPosts } from '../../../utils/posts';
import { getTags, type TaxonomyGroup } from '../../../utils/taxonomy';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return getTags(posts).map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

interface Props {
  tag: TaxonomyGroup;
}
const { tag } = Astro.props;
---

<ListLayout title={`Tag: ${tag.name}`} description={`Posts tagged “${tag.name}”.`}>
  <PostList posts={tag.posts} />
</ListLayout>
