# Cloudflare Web Analytics site token for adrianhall.uk (see
# MIGRATION_PLAN.md § M4/M5 and src/components/Analytics.astro). Provisioned
# in M5; must be prefixed PUBLIC_ to be readable at build time by Astro/Vite.
PUBLIC_CF_BEACON_TOKEN=

# Cloudflare credentials used by `npm run publish` (local) and the
# `deploy.yml` GitHub Actions workflow (as repo secrets, not from this file)
# to run `wrangler deploy`. Never commit real values — this file is just
# documentation of the shape; the actual `.env` is gitignored.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
