---
// Categories landing -> `/categories/`. This is an ADDITIVE improvement over the
// old site (which had per-category pages but no landing index).
import Base from '../../layouts/Base.astro';
import { getSortedPosts } from '../../utils/posts';
import { getCategories } from '../../utils/taxonomy';

const posts = await getSortedPosts();
const categories = getCategories(posts);
---

<Base title="Categories">
  <h1>Categories</h1>
  <ul>
    {
      categories.map((category) => (
        <li>
          <a href={`/categories/${category.slug}/`}>{category.name}</a> ({category.posts.length})
        </li>
      ))
    }
  </ul>
</Base>
