---
// Milestone 3 review-gate shell for Design direction C ("Editorial spacing,
// developer palette") — added after owner feedback: B's colors/fonts, A's
// spacing/design, wider than both. Delete alongside `src/design-preview/` and
// `src/pages/design-preview/` once M4 picks a direction and builds the real
// `src/layouts/Base.astro`.
import './styles/design-c.css';
import PreviewChrome from './PreviewChrome.astro';

interface Props {
  title: string;
  description?: string;
  page: 'home' | 'post';
}

const {
  title,
  description = "Design direction C (editorial spacing, developer palette) — Milestone 3 review build.",
  page,
} = Astro.props;
---

<PreviewChrome directionKey="c" title={title} description={description} page={page}>
  <slot />
</PreviewChrome>
