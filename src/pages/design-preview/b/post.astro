---
// Milestone 3 review page — Direction B, single real post view. Renders the
// SHOWCASE_POST_ID entry through the real MDX pipeline (same <Notice>,
// <Figure>, <Mermaid>, and Expressive Code output the production post pages
// use) so the review reflects genuine rendered content, not a mock-up.
// Not a production route (see MIGRATION_PLAN.md § M3).
import { getEntry, render } from 'astro:content';
import PreviewLayoutB from '../../../design-preview/PreviewLayoutB.astro';
import { getPostDate } from '../../../utils/posts';
import { readingTimeMinutes } from '../../../design-preview/content-meta';
import { SHOWCASE_POST_ID } from '../../../design-preview/config';

const post = await getEntry('posts', SHOWCASE_POST_ID);
if (!post) {
  throw new Error(`design-preview: showcase post "${SHOWCASE_POST_ID}" not found.`);
}

const { Content } = await render(post);
const date = getPostDate(post);
const minutes = readingTimeMinutes(post.body);
---

<PreviewLayoutB title={post.data.title} page="post">
  <div class="article-grid">
    <article class="prose">
      <h1 class="page-title">{post.data.title}</h1>
      <p class="post-meta">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span aria-hidden="true">·</span>
        <span>{minutes} min read</span>
      </p>
      <Content />
    </article>

    <aside class="article-rail">
      <h2>On this post</h2>
      <dl>
        <dt>Published</dt>
        <dd>{date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</dd>
        <dt>Reading time</dt>
        <dd>{minutes} min</dd>
        {post.data.categories.length > 0 && (
          <>
            <dt>Categories</dt>
            <dd>{post.data.categories.join(', ')}</dd>
          </>
        )}
      </dl>
      {post.data.tags.length > 0 && (
        <ul class="tag-list">
          {post.data.tags.map((tag) => (
            <li class="tag-pill">{tag}</li>
          ))}
        </ul>
      )}
    </aside>
  </div>
</PreviewLayoutB>
