---
// Home page 1 -> `/`. Pages 2..N live at `/page/<num>/`.
import ListLayout from '../layouts/ListLayout.astro';
import PostList from '../components/PostList.astro';
import { getSortedPosts, PER_PAGE } from '../utils/posts';

const posts = await getSortedPosts();
const totalPages = Math.max(1, Math.ceil(posts.length / PER_PAGE));
const pagePosts = posts.slice(0, PER_PAGE);
---

<ListLayout
  title="Because Developers are Awesome"
  description="Musings about cloud development."
  lede="Musings about cloud development."
  pagination={{ nextHref: totalPages > 1 ? '/page/2/' : null }}
>
  <PostList posts={pagePosts} />
</ListLayout>
