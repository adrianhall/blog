---
// Generic outline pictogram, used on the About page's sketchnote-style
// cards. Path data is taken verbatim from Lucide (lucide-static, ISC
// license — https://lucide.dev), matching the exact inline-SVG conventions
// (viewBox 0 0 24 24, fill="none", stroke="currentColor", stroke-width 2,
// round caps/joins) already used by ThemeToggle.astro and ShareButtons.astro
// so this component blends in with the rest of the site rather than
// introducing a second icon style.
export type IconName =
  | 'compass'
  | 'pen-tool'
  | 'terminal'
  | 'shuffle'
  | 'bike'
  | 'box'
  | 'book-open'
  | 'map-pin'
  | 'heart'
  | 'sparkles'
  | 'message-circle'
  | 'rocket'
  | 'search'
  | 'mail';

interface Props {
  name: IconName;
  /** Accessible label. Omit for a purely decorative icon (the default). */
  label?: string;
}

const { name, label } = Astro.props;

