---
// Posts-listing pagination 2..N -> `/posts/page/<num>/`. Page 1 is `/posts/`.
import ListLayout from '../../../../layouts/ListLayout.astro';
import PostList from '../../../../components/PostList.astro';
import { getSortedPosts, PER_PAGE } from '../../../../utils/posts';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  const totalPages = Math.max(1, Math.ceil(posts.length / PER_PAGE));
  const paths = [];
  for (let num = 2; num <= totalPages; num++) {
    paths.push({ params: { num: String(num) }, props: { num, totalPages } });
  }
  return paths;
}

interface Props {
  num: number;
  totalPages: number;
}
const { num, totalPages } = Astro.props;
const posts = await getSortedPosts();
const pagePosts = posts.slice((num - 1) * PER_PAGE, num * PER_PAGE);

const prevHref = num === 2 ? '/posts/' : `/posts/page/${num - 1}/`;
const nextHref = num < totalPages ? `/posts/page/${num + 1}/` : null;
---

<ListLayout
  title={`Posts — page ${num} of ${totalPages}`}
  pagination={{ prevHref, nextHref }}
>
  <PostList posts={pagePosts} />
</ListLayout>
