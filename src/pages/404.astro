---
// Cloudflare Workers Static Assets serves this for any unmatched path (see
// https://developers.cloudflare.com/workers/static-assets/routing/ —
// `not_found_handling` defaults to serving `404.html` when present).
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found"
  description="This page doesn't exist."
  canonicalPath="/404.html"
  noindex
>
  <div class="error-page">
    <p class="error-code">404</p>
    <h1 class="page-title">Page not found</h1>
    <p class="page-lede">
      That page doesn't exist — it may have moved, or the link is out of date.
    </p>
    <p><a href="/">← Back to the home page</a></p>
  </div>
</Base>
