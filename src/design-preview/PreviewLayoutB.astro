---
// Milestone 3 review-gate shell for Design direction B ("Technical / developer").
// Delete alongside `src/design-preview/` and `src/pages/design-preview/` once
// M4 picks a direction and builds the real `src/layouts/Base.astro`.
import './styles/design-b.css';
import PreviewChrome from './PreviewChrome.astro';

interface Props {
  title: string;
  description?: string;
  page: 'home' | 'post';
}

const {
  title,
  description = 'Design direction B (technical / developer) — Milestone 3 review build.',
  page,
} = Astro.props;
---

<PreviewChrome directionKey="b" title={title} description={description} page={page}>
  <slot />
</PreviewChrome>
