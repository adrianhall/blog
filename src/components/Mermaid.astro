---
// Minimal Mermaid component (M2). Replaces the old raw `<pre class="mermaid">`
// blocks. The diagram source is passed as a `code` string prop (not children)
// so its `-->`, `{}` and `<>` syntax never hits the MDX parser. This renders the
// standard `<pre class="mermaid">` target element; the client-side mermaid
// script that turns it into an SVG is wired up in M4 (per the M1 notes).
interface Props {
  code: string;
}
const { code } = Astro.props;
---

<pre class="mermaid">{code}</pre>
