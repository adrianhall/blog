---
// Simple, dependency-free share links (the "native" option from
// MIGRATION_PLAN.md § M4 — "Share component (AddToAny or native)"). No
// third-party script is loaded (AddToAny would mean shipping its tracking
// JS, which cuts against the rest of this migration's privacy stance —
// Clarity dropped, Disqus dropped in favor of Giscus, analytics moved to
// Cloudflare's cookie-less Web Analytics).
//
// **Platform list matches the old site's actual AddToAny config**
// (`_includes/social-share.html` in the source repo), not a generic
// "popular networks" guess: copy link, email, Bluesky, Facebook, LinkedIn,
// Mastodon, Reddit, Threads. X/Twitter was never in that list and is
// intentionally excluded. Slashdot was in the old list too, but its own
// share/bookmark feature has been dead since 2018 — confirmed live while
// fixing this
// (`curl https://slashdot.org/bookmark.pl?...` → "New bookmark creation is
// no longer supported") — so it's dropped rather than shipping a button that
// leads to a dead feature on Slashdot's own site. Brand icon paths are from
// the CC0-licensed Simple Icons project (simpleicons.org); the generic
// email/native-share/copy-link icons are Lucide-style outline icons to match
// this component's original two.
//
// Also renders a "Share via…" button using the Web Share API (progressively
// enhanced — hidden unless `navigator.share` exists) and a "Copy link"
// button using the Clipboard API with an `execCommand` fallback.
interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;
---

<div class="share" data-share data-url={url} data-title={title}>
  <span class="share__label">Share:</span>
  <button type="button" class="share__link" data-share-native hidden aria-label="Share via…">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7"></path>
      <polyline points="16 6 12 2 8 6"></polyline>
      <line x1="12" y1="2" x2="12" y2="15"></line>
    </svg>
  </button>
  <button type="button" class="share__link" data-share-copy aria-label="Copy link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
    </svg>
  </button>
  <a
    class="share__link"
    aria-label="Share by email"
    href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
      <rect x="2" y="4" width="20" height="16" rx="2"></rect>
    </svg>
  </a>
  <a
    class="share__link"
    aria-label="Share on Bluesky"
    target="_blank"
    rel="noopener noreferrer"
    href={`https://bsky.app/intent/compose?text=${encodeURIComponent(`${title} ${url}`)}`}
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037-.856 3.061-3.978 3.842-6.755 3.37 4.854.826 6.089 3.562 3.422 6.299-5.065 5.196-7.28-1.304-7.847-2.97-.104-.305-.152-.448-.153-.327 0-.121-.05.022-.153.327-.568 1.666-2.782 8.166-7.847 2.97-2.667-2.737-1.432-5.473 3.422-6.3-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026"></path>
    </svg>
  </a>
  <a
    class="share__link"
    aria-label="Share on Facebook"
    target="_blank"
    rel="noopener noreferrer"
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`}
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"></path>
    </svg>
  </a>
  <a
    class="share__link"
    aria-label="Share on LinkedIn"
    target="_blank"
    rel="noopener noreferrer"
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`}
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M6.94 5a2 2 0 1 1-4-.002 2 2 0 0 1 4 .002ZM7 8.48H3V21h4V8.48Zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-3.96 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.68-2.91V8.48Z"></path>
    </svg>
  </a>
  <button type="button" class="share__link" data-share-mastodon aria-label="Share on Mastodon">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"></path>
    </svg>
  </button>
  <a
    class="share__link"
    aria-label="Share on Reddit"
    target="_blank"
    rel="noopener noreferrer"
    href={`https://www.reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`}
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.373 0 0 5.373 0 12c0 3.314 1.343 6.314 3.515 8.485l-2.286 2.286C.775 23.225 1.097 24 1.738 24H12c6.627 0 12-5.373 12-12S18.627 0 12 0Zm4.388 3.199c1.104 0 1.999.895 1.999 1.999 0 1.105-.895 2-1.999 2-.946 0-1.739-.657-1.947-1.539v.002c-1.147.162-2.032 1.15-2.032 2.341v.007c1.776.067 3.4.567 4.686 1.363.473-.363 1.064-.58 1.707-.58 1.547 0 2.802 1.254 2.802 2.802 0 1.117-.655 2.081-1.601 2.531-.088 3.256-3.637 5.876-7.997 5.876-4.361 0-7.905-2.617-7.998-5.87-.954-.447-1.614-1.415-1.614-2.538 0-1.548 1.255-2.802 2.803-2.802.645 0 1.239.218 1.712.585 1.275-.79 2.881-1.291 4.64-1.365v-.01c0-1.663 1.263-3.034 2.88-3.207.188-.911.993-1.595 1.959-1.595Zm-8.085 8.376c-.784 0-1.459.78-1.506 1.797-.047 1.016.64 1.429 1.426 1.429.786 0 1.371-.369 1.418-1.385.047-1.017-.553-1.841-1.338-1.841Zm7.406 0c-.786 0-1.385.824-1.338 1.841.047 1.017.634 1.385 1.418 1.385.785 0 1.473-.413 1.426-1.429-.046-1.017-.721-1.797-1.506-1.797Zm-3.703 4.013c-.974 0-1.907.048-2.77.135-.147.015-.241.168-.183.305.483 1.154 1.622 1.964 2.953 1.964 1.33 0 2.47-.81 2.953-1.964.057-.137-.037-.29-.184-.305-.863-.087-1.795-.135-2.769-.135Z"></path>
    </svg>
  </a>
  <a
    class="share__link"
    aria-label="Share on Threads"
    target="_blank"
    rel="noopener noreferrer"
    href={`https://www.threads.net/intent/post?text=${encodeURIComponent(`${title} ${url}`)}`}
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"></path>
    </svg>
  </a>
</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-share]');
  if (root) {
    const url = root.dataset.url ?? '';
    const title = root.dataset.title ?? '';

    const nativeButton = root.querySelector<HTMLButtonElement>('[data-share-native]');
    if (nativeButton && typeof navigator.share === 'function') {
      nativeButton.hidden = false;
      nativeButton.addEventListener('click', () => {
        navigator.share({ title, url }).catch(() => {
          // Ignore — most rejections are the user dismissing the share sheet.
        });
      });
    }

    const copyButton = root.querySelector<HTMLButtonElement>('[data-share-copy]');
    copyButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        // Fallback for browsers without Clipboard API / insecure contexts.
        const input = document.createElement('textarea');
        input.value = url;
        input.style.position = 'fixed';
        input.style.opacity = '0';
        document.body.appendChild(input);
        input.select();
        // `execCommand` is deprecated but remains the only fallback for
        // browsers/contexts without the async Clipboard API. Called via an
        // untyped indirection so the deprecation hint doesn't follow it here.
        const legacyCopy: (command: string) => boolean = (document as unknown as { execCommand: (command: string) => boolean }).execCommand.bind(document);
        legacyCopy('copy');
        document.body.removeChild(input);
      }
      copyButton.dataset.copied = 'true';
      const label = copyButton.getAttribute('aria-label');
      copyButton.setAttribute('aria-label', 'Link copied');
      setTimeout(() => {
        delete copyButton.dataset.copied;
        if (label) copyButton.setAttribute('aria-label', label);
      }, 2000);
    });

    // Mastodon is federated — there's no single "mastodon.com" to link to.
    // The widely-used pattern (AddToAny's own Mastodon button does this too)
    // is to ask the visitor which instance they're on once, remember it, and
    // send them to that instance's own compose-intent endpoint
    // (`https://<instance>/share?text=...`, documented behaviour: redirects
    // to sign-in if logged out, straight to a pre-filled compose box if
    // logged in).
    const mastodonButton = root.querySelector<HTMLButtonElement>('[data-share-mastodon]');
    mastodonButton?.addEventListener('click', () => {
      const STORAGE_KEY = 'bda-mastodon-instance';
      let instance: string | null = null;
      try {
        instance = localStorage.getItem(STORAGE_KEY);
      } catch {
        // Ignore (e.g. storage disabled) — falls through to prompting below.
      }

      if (!instance) {
        const input = window.prompt('Which Mastodon instance are you on? (e.g. mastodon.social)');
        if (!input) return;
        instance = input.trim().replace(/^https?:\/\//, '').replace(/\/.*$/, '');
        if (!instance) return;
        try {
          localStorage.setItem(STORAGE_KEY, instance);
        } catch {
          // Ignore — the share still works this once, just isn't remembered.
        }
      }

      const text = `${title} ${url}`;
      window.open(`https://${instance}/share?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
    });
  }
</script>
