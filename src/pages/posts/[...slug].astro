---
// Individual post route. This is a FILE-style route (not `[...slug]/index.astro`)
// so under `build.format: "preserve"` each page is emitted as a literal
// `.html` file: `/posts/<id>.html` — preserving the exact legacy Jekyll URLs.
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getPostDate, getPostUrl } from '../../utils/posts';
import { excerptOf, readingTimeMinutes } from '../../utils/content';
import type { Post } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    // `post.id` already includes the year directory, e.g.
    // `2017/2017-08-11-integrating-react-native-typescript-mobx`.
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { Content, headings } = await render(post);
const date = getPostDate(post);
const minutes = readingTimeMinutes(post.body);
const description = excerptOf(post.body, 160);
---

<PostLayout
  title={post.data.title}
  description={description}
  path={getPostUrl(post)}
  date={date}
  minutes={minutes}
  categories={post.data.categories}
  tags={post.data.tags}
  headings={headings}
>
  <Content />
</PostLayout>
